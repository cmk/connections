#!/usr/bin/env bash
# .githooks/pre-commit — git-side pre-commit gate (cheap checks).
#
# Companion to:
#
#   - `.claude/settings.json` runs DURING agent iteration, before
#     the Bash call that invokes git fires. Catches issues without
#     the agent needing to actually invoke git, which is faster
#     feedback. But: it sees the staged diff at PreToolUse time,
#     which means a chained command like `git add file && git
#     commit -m ...` slips through — the `git add` half hasn't
#     run yet at hook fire, so `check_pii.sh` reads an empty
#     pre-add staged diff.
#
#   - `.githooks/pre-push` runs expensive checks once per push
#     instead of once per commit.
#
# This file holds cheap deterministic checks that catch high-leverage
# mistakes at commit time after staging. Activate hooks on a fresh
# clone with:
#
#     git config core.hooksPath .githooks
#
# Bypass with `--no-verify` only when explicitly authorized.
#
# Exit codes follow git convention: nonzero blocks the commit.

set -euo pipefail

repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"

step() {
  printf 'pre-commit: %s\n' "$*"
}

# 1. cargo fmt — blocking. Drift aborts the commit. Run
#    `cargo fmt --all` to fix.
step "cargo fmt --all -- --check"
cargo fmt --all -- --check

# 2. PII / secret scan — blocking.
step "scripts/check_pii.sh"
scripts/check_pii.sh

# 3. README-mirror drift check — blocking. Fails if README sections
#    that are mirrored from rustdoc have drifted out of sync.
step "scripts/check_readme_mirror.sh"
scripts/check_readme_mirror.sh

step "OK"
